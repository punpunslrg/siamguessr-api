datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// -----------------------------------------------------
// ENUMS
// -----------------------------------------------------

enum Role {
  user
  admin
}

enum UserStatus {
  pending
  active
  banned
}

enum AuthProvider {
  local
  google
  facebook
}

enum RoomMode {
  single
  multi
}

enum RoomStatus {
  waiting
  playing
  finished
}

enum PlayerStatus {
  ready
  waiting
  playing
  left
}

enum FriendStatus {
  pending
  accepted
  declined
  blocked
}

enum Difficulty {
  classic
  challenge
}

// optional

enum SubscriptionTierName {
  free
  basic
  pro
  elite
}

enum SubscriptionStatus {
  active
  cancel
}

// -----------------------------------------------------
// MODELS
// -----------------------------------------------------

model User {
  id        String       @id @default(cuid())
  email     String       @unique
  password  String?
  username  String?
  image     String?
  role      Role         @default(user)
  status    UserStatus   @default(active)
  provider  AuthProvider @default(local)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // --- Relations ---
  hostedRooms              Room[]                    @relation("Host")
  roomPlayers              RoomPlayer[]
  guesses                  Guess[]
  leaderboard              Leaderboard[]
  gameScoreHistory         GameScoreHistory[]
  sentFriendRequests       Friend[]                  @relation("SentRequests")
  receivedFriendRequests   Friend[]                  @relation("ReceivedRequests")
  subscription             Subscription?
  conversationParticipants ConversationParticipant[]
  messages                 Message[]

  // --- ADD THIS RELATION ---
  winRate WinRate[]
}

// --- ADD THIS NEW MODEL ---
model WinRate {
  id            String      @id @default(cuid())
  difficulty    Difficulty
  wins          Int         @default(0)
  losses        Int         @default(0)
  draws         Int         @default(0)
  gamesPlayed   Int         @default(0)
  winPercentage Float       @default(0.0)
  lastUpdated   DateTime    @updatedAt

  // --- Relations ---
  userId String 
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, difficulty])
}

model Room {
  id         String     @id @default(cuid())
  code       String?
  mode       RoomMode   @default(single)
  difficulty Difficulty
  status     RoomStatus @default(waiting)
  maxPlayers Int        @default(1)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // --- Relations ---
  hostId           String
  host             User               @relation("Host", fields: [hostId], references: [id], onDelete: Cascade)
  players          RoomPlayer[]
  rounds           Round[]
  gameScoreHistory GameScoreHistory[]
}

model RoomPlayer {
  totalScore Int          @default(0)
  isHost     Boolean      @default(false)
  status     PlayerStatus @default(playing)
  joinedAt   DateTime     @default(now())

  // --- Relations ---
  roomId String
  userId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@unique([userId, roomId], name: "userId_roomId")
}

model Round {
  id          String    @id @default(cuid())
  roundNumber Int
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  endedAt     DateTime?

  // --- Relations ---
  roomId     String
  room       Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  guesses    Guess[]
  locationId String
  location   CuratedLocation @relation(fields: [locationId], references: [id])
}

model Guess {
  id         String   @id @default(cuid())
  guessedLat Decimal? @db.Decimal(10, 7)
  guessedLng Decimal? @db.Decimal(10, 7)
  distance   Float? // in kilometers
  score      Int      @default(0)
  guessedAt  DateTime @default(now())

  // --- Relations ---
  roundId String
  userId  String
  round   Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roundId, userId])
}

model Leaderboard {
  id          Int      @id @default(autoincrement())
  totalGames  Int      @default(0)
  averageTop5 Int      @default(0)
  updatedAt   DateTime @updatedAt

  // --- Relations ---
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mode       RoomMode
  difficulty Difficulty

  @@unique([userId, mode, difficulty])
}

model GameScoreHistory {
  id       Int      @id @default(autoincrement())
  score    Int
  playedAt DateTime @default(now())
  rank     Int?

  difficulty Difficulty
  // --- Relations ---
  roomId     String
  userId     String
  room       Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Friend {
  status     FriendStatus
  createdAt  DateTime     @default(now())
  responseAt DateTime?

  // --- Relations ---
  requesterId String
  receiverId  String
  requester   User   @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    User   @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@id([requesterId, receiverId])
}

// -----------------------------------------------------
// Optional: Subscription & Chat Models
// -----------------------------------------------------

model Subscription {
  id String @id @default(cuid())

  // --- Stripe Specific Fields (สำคัญมาก) ---
  stripeSubscriptionId String @unique // ID ของ Subscription ที่ Stripe สร้างให้
  stripeCustomerId     String @unique // ID ของ Customer ที่ Stripe สร้างให้ user คนนี้

  // --- Subscription Status ---
  status             String // e.g., "active", "canceled", "past_due" (ตรงกับของ Stripe)
  currentPeriodStart DateTime // วันที่เริ่มต้นรอบบิลปัจจุบัน
  currentPeriodEnd   DateTime // วันที่จะหมดอายุ/ตัดเงินรอบถัดไป (สำคัญมาก)
  canceledAt         DateTime? // วันที่กดยกเลิก
  endedAt            DateTime? // วันที่หมดอายุจริงๆ หลังยกเลิก

  // --- Relations ---
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // เปลี่ยนจาก Enum มาเป็น Relation ที่เชื่อมกับ Tier โดยตรง
  tierId String
  tier   SubscriptionTier @relation(fields: [tierId], references: [id])
}

model SubscriptionTier {
  id          String               @id @default(cuid())
  name        SubscriptionTierName @unique // ชื่อของระดับขั้น (free, pro, elite)
  description String?
  price       Decimal              @db.Decimal(10, 2) // ราคาต่อรอบบิล
  isActive    Boolean              @default(true) // เปิด/ปิดการขาย tier นี้

  // --- Stripe Specific Fields ---
  // ID ของ Price ที่คุณสร้างใน Stripe Dashboard (สำคัญที่สุด)
  // เช่น price_12345 สำหรับ Pro Plan, price_67890 สำหรับ Elite Plan
  stripePriceId String @unique

  // --- Relations ---
  // Tier นี้มีผู้ใช้สมัครอยู่กี่คน
  subscriptions Subscription[]
}

model Conversation {
  id        String   @id @default(cuid())
  isGroup   Boolean  @default(false)
  createdAt DateTime @default(now())

  // --- Relations ---
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  joinedAt DateTime @default(now())

  // --- Relations ---
  conversationId String
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
}

model Message {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())

  // --- Relations ---
  conversationId String
  senderId       String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model CuratedLocation {
  id            String    @id @default(cuid())
  lat           Decimal   @db.Decimal(10, 7)
  lng           Decimal   @db.Decimal(10, 7)
  countryCode   String? // e.g., "TH" for Thailand
  description   String? // e.g., "Road in front of Victory Monument"
  isVerified    Boolean   @default(true) // To flag if a location becomes broken
  lastCheckedAt DateTime? // Timestamp of the last verification check

  // --- Relations ---
  // This shows which rounds have used this location
  rounds Round[]
}
